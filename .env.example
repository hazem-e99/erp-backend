# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/erp?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=development

# CORS (comma-separated for multiple origins: web + mobile)
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://localhost:19006

# Frontend base URL — used for OAuth callback redirect back to the UI
FRONTEND_URL=http://localhost:3000

# Backup module
BACKUP_STORAGE_DRIVER=google-drive     # google-drive | local (dev only)
BACKUP_DIR=./uploads/backup            # used only when driver=local
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=6
BACKUP_RESTORE_PHRASE=RESTORE PRODUCTION DATABASE
BACKUP_ALLOW_FOREIGN=false
BACKUP_TRIGGER_SECRET=change-me-48-hex-chars-for-github-actions-bearer
BACKUP_ENCRYPTION_KEY=change-me-32-hex-chars-for-token-encryption
MONGODUMP_BIN=./bin/mongodump
MONGORESTORE_BIN=./bin/mongorestore

# Google OAuth for Drive backups — obtain at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/backup/google/callback
GOOGLE_DRIVE_FOLDER_NAME=ERP-Backups
